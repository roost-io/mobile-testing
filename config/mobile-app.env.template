# ============================================================
# Roost UI Test Generator — Mobile Config
# Copy to mobile-app.env and fill in values before running.
# ============================================================

# --- AI Provider (Gemini) ---
AI_TYPE=gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Azure OpenAI (kept for reference, not used when AI_TYPE=gemini) ---
# AI_TYPE=azure_open_ai
# OPENAI_API_MODEL=gpt-4
# OPENAI_BASE_URL=https://api.openai.com/v1
# AZURE_OPENAI_ENDPOINT=
# AZURE_DEPLOYMENT_NAME=
# AZURE_OPENAI_VERSION="2024-08-01-preview"
# AZURE_OPENAI_API_KEY=
# AZURE_USERNAME=
# AZURE_PASSWORD=

# --- Web UI config (carried over) ---
UI_LOGIN_TYPE=embedded_login
UI_SITE_USERNAME=
UI_SITE_PASSWORD=
USER_LANGUAGE=english
SSL_VERIFY=false
BROWSER_USE_HEADLESS="false"
ENABLE_POM_TESTS="true"
ENABLE_AGENTIC_GENERATION="true"
DISABLE_PLAYWRIGHT_TESTS="true"
AI_PRE_PROCESSING="false"

# --- AWS (not used for mobile, kept for parity) ---
AWS_REGION=us-east-1
# AWS_BEDROCK_MODEL=global.anthropic.claude-sonnet-4-20250514-v1:0
# AWS_DEFAULT_REGION=us-east-1

# --- Roost context ---
USE_TYPE=cli
GRPC_VERBOSITY=NONE
ROOST_CUSTOMER=
ROOST_CONTEXT=

# --- Web output dirs (not used for mobile but harmless) ---
USER_SCENARIO_FILE_PATH=
UI_OUTPUT_DIR=./generated_tests/
UI_TEMP_DIR=./temp_info/
UI_OTP_SCRIPT_PATH=

# ============================================================
# Mobile Testing (minitap mobile-use)
# ============================================================

MOBILE_TESTING_ENABLED=true

# Platform: android | ios
MOBILE_PLATFORM=android

# App to test — Android package name (leave blank to allow agent to navigate all system apps freely)
MOBILE_APP_PACKAGE=io.appium.android.apis

# Android launch activity (leave blank to use app default)
MOBILE_APP_ACTIVITY=io.appium.android.apis.ApiDemos

# Path to .apk file (leave blank if app is already installed on device)
MOBILE_APP_PATH=./sample_apps/ApiDemos-debug.apk

# iOS bundle ID (only needed for iOS)
MOBILE_BUNDLE_ID=

# Device serial from `adb devices` (leave blank to use first connected device)
MOBILE_DEVICE_NAME=

# Android OS version (e.g. 14, 13)
MOBILE_PLATFORM_VERSION=14

# Automation engine — UiAutomator2 (Android) | XCUITest (iOS)
MOBILE_AUTOMATION_NAME=UiAutomator2

# Appium server URL
APPIUM_SERVER_URL=http://localhost:4723

# Login credentials (embedded in agent goal text — no type_secret in minitap)
MOBILE_USERNAME=
MOBILE_PASSWORD=

# Path to scenario file (.txt, .md, .feature, or .json)
MOBILE_SCENARIO_FILE_PATH=./scenarios/android-api-demo.txt

# Agent limits
MOBILE_MAX_STEPS=100
MOBILE_TIMEOUT=

# Reset app state between test runs
MOBILE_RESET_APP=true
